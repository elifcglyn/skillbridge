generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model Profile {
  id            String   @id @db.Uuid
  fullName      String?  @map("full_name")
  firstName     String?  @map("first_name")
  lastName      String?  @map("last_name")
  avatarUrl     String?  @map("avatar_url")
  university    String?
  department    String?
  bio           String?
  teaches       String[]
  learns        String[]
  profilePublic Boolean? @map("profile_public")
  skillPoints   Int?     @map("skill_points")
  coinBalance   Int      @default(0) @map("coin_balance")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("profiles")
  @@schema("public")
}

model PointEvent {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  amount           Int
  eventType        String   @default("manual") @map("event_type")
  description      String   @default("")
  relatedSessionId String?  @map("related_session_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt(sort: Desc)], map: "point_events_user_created_idx")
  @@map("point_events")
  @@schema("public")
}

model MarketPurchase {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  productId      String   @map("product_id")
  pointEventId   String   @unique(map: "market_purchases_point_event_id_key") @map("point_event_id") @db.Uuid
  cost           Int
  status         String   @default("active")
  idempotencyKey String   @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, idempotencyKey], map: "market_purchases_user_idempotency_key")
  @@index([userId, createdAt(sort: Desc)], map: "market_purchases_user_created_idx")
  @@map("market_purchases")
  @@schema("public")
}

model Review {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String?  @map("session_id") @db.Uuid
  reviewerId String?  @map("reviewer_id") @db.Uuid
  revieweeId String?  @map("reviewee_id") @db.Uuid
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([sessionId, reviewerId], map: "reviews_session_id_reviewer_id_key")
  @@index([revieweeId, createdAt(sort: Desc)], map: "reviews_reviewee_created_idx")
  @@index([reviewerId, createdAt(sort: Desc)], map: "reviews_reviewer_created_idx")
  @@map("reviews")
  @@schema("public")
}

model Connection {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId String?   @map("requester_id") @db.Uuid
  receiverId  String?   @map("receiver_id") @db.Uuid
  status      String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([receiverId, status, createdAt(sort: Desc)], map: "connections_receiver_status_created_idx")
  @@index([requesterId, createdAt(sort: Desc)], map: "connections_requester_created_idx")
  @@map("connections")
  @@schema("public")
}

model Match {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  matchedUserId    String?   @map("matched_user_id") @db.Uuid
  skillName        String?   @map("skill_name")
  matchedSkillName String?   @map("matched_skill_name")
  status           String?
  matchScore       Int?      @map("match_score")
  distanceKm       Decimal?  @map("distance_km") @db.Decimal
  createdAt        DateTime? @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt(sort: Desc)], map: "matches_user_created_idx")
  @@index([matchedUserId, createdAt(sort: Desc)], map: "matches_matched_user_created_idx")
  @@map("matches")
  @@schema("public")
}

model Message {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderId   String?   @map("sender_id") @db.Uuid
  receiverId String?   @map("receiver_id") @db.Uuid
  content    String
  isRead     Boolean?  @default(false) @map("is_read")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([receiverId, isRead, createdAt(sort: Desc)], map: "messages_receiver_read_created_idx")
  @@index([senderId, receiverId, createdAt], map: "messages_pair_created_idx")
  @@map("messages")
  @@schema("public")
}

model Notification {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  title          String
  message        String
  description    String    @default("")
  type           String
  content        String
  actorName      String?   @map("actor_name")
  actorAvatarUrl String?   @map("actor_avatar_url")
  actionStatus   String    @default("none") @map("action_status")
  metadata       Json      @default("{}")
  relatedUrl     String?   @map("related_url")
  isRead         Boolean?  @default(false) @map("is_read")
  readAt         DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  dismissedAt    DateTime? @map("dismissed_at") @db.Timestamptz(6)

  @@index([userId, isRead, createdAt(sort: Desc)], map: "notifications_user_read_created_idx")
  @@index([userId, dismissedAt, createdAt(sort: Desc)], map: "notifications_user_visible_idx")
  @@map("notifications")
  @@schema("public")
}

model Session {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId         String?  @map("match_id") @db.Uuid
  mentorId        String?  @map("mentor_id") @db.Uuid
  studentId       String?  @map("student_id") @db.Uuid
  learnerId       String?  @map("learner_id") @db.Uuid
  title           String?
  skillName       String?  @map("skill_name")
  scheduledAt     DateTime @map("scheduled_at") @db.Timestamptz(6)
  durationMinutes Int?     @map("duration_minutes")
  deliveryType    String?  @map("delivery_type")
  status          String?
  meetingLink     String?  @map("meeting_link")
  color           String?
  emoji           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([mentorId, scheduledAt], map: "sessions_mentor_scheduled_idx")
  @@index([studentId, scheduledAt], map: "sessions_student_scheduled_idx")
  @@index([learnerId, scheduledAt], map: "sessions_learner_scheduled_idx")
  @@index([matchId, scheduledAt], map: "sessions_match_scheduled_idx")
  @@map("sessions")
  @@schema("public")
}
